<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Ocean View Resort - Reservation System</display-name>
    <description>
        Online Room Reservation System for Ocean View Resort, Galle, Sri Lanka
    </description>

    <!-- Session timeout: 30 minutes of inactivity -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Default page when accessing the application -->
    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

    <!-- Custom error pages instead of Tomcat stack traces -->
    <error-page>
        <error-code>404</error-code>
        <location>/error404.jsp</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/error500.jsp</location>
    </error-page>

</web-app>